# PremTracker Environment
# This file documents all environment variables required for the backend.
# Copy this to .env locally and fill in real values.
# For production (Render), set these in the dashboard instead.

# Runtime
NODE_ENV=development
PORT=3001
TRUST_PROXY=1
APP_TIMEZONE=America/New_York

# Database
DATABASE_URL=

# Auth / JWT
JWT_ACCESS_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_COOKIE_DAYS=7

# Cookies
# Local development:
#   COOKIE_SAMESITE=lax
#   COOKIE_SECURE=false
#
# Production (Render API + Vercel frontend):
#   COOKIE_SAMESITE=none
#   COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Public Backend URL
# Used for email verification links.
# Local:http://localhost:3001
#
# Production: https://your-render-service.onrender.com
#
# Note: If not set in production, app may fallback to RENDER_EXTERNAL_URL
PUBLIC_BASE_URL=http://localhost:3001

# Frontend Origins (CORS)
# Comma-separated list of allowed origins
FRONTEND_ORIGINS=http://localhost:3000

# Optional legacy fallback (not required if using FRONTEND_ORIGINS)
# FRONTEND_ORIGIN=http://localhost:3000

# Email Verification Redirect
# Optional: redirect users to frontend after verifying 
# If empty, backend returns JSON instead
EMAIL_VERIFY_REDIRECT_URL=

# Password Reset Redirect
# Optional: frontend page that reads ?token=...
# If empty, backend returns a JSON fallback on GET /api/auth/reset-password
PASSWORD_RESET_REDIRECT_URL=

# Rate Limiting (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email / Resend
# Local:EMAIL_MODE=demo (no real emails sent)
#
# Production:
#   EMAIL_MODE=live
#   RESEND_API_KEY required
#   EMAIL_FROM must be verified domain
EMAIL_MODE=demo
RESEND_API_KEY=
EMAIL_FROM=

# Sports API / Data Sync
SPORTS_API_KEY=

# Competition config
EPL_ID=7

# Sync tuning
MAX_API_CALLS=100
LAST_RESULTS=3
NEXT_FIXTURES=3
RESULTS_LOOKBACK_DAYS=45

# Optional season bounds (used by scripts)
EPL_START_ISO=2025-08-15T00:00:00Z
EPL_END_ISO=2026-03-15T23:59:59Z
