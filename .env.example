# App
NODE_ENV=development
PORT=3001
TRUST_PROXY=1
FRONTEND_ORIGIN=http://localhost:3000
# Comma-separated allowed origins are supported
# FRONTEND_ORIGIN=http://localhost:3000,https://your-frontend-domain.com
PUBLIC_BASE_URL=http://localhost:3001

# Auth
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
ACCESS_TOKEN_TTL=15m
REFRESH_COOKIE_DAYS=7
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Database
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Upstash rate limiter
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sports API sync
SPORTS_API_KEY=
LAST_RESULTS=3
NEXT_FIXTURES=3
RESULTS_LOOKBACK_DAYS=45
MAX_API_CALLS=100
APP_TIMEZONE=America/New_York

# Email
EMAIL_MODE=demo
EMAIL_FROM=PremTracker <onboarding@resend.dev>
RESEND_API_KEY=
